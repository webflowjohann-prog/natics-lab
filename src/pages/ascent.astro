---
import Layout from '../layouts/Layout.astro';
const IMG = {
  hero: 'https://images.ctfassets.net/drib7o8rcbyf/64oMt8msJ0h1l75i0ejdfs/51022d60a8ac8c3915436d1ede080321/CORE_ANCILLARIES_MODULE__PT_375x563-min.jpg?fm=webp&fit=fill&w=1920',
  split: 'https://images.ctfassets.net/drib7o8rcbyf/7xaVBLqmztmYQGrXBg0pqx/01d2a0130ad7a05585663d9600b437eb/CORE_ANCILLARIES_MODULE__GF_375x563-min.jpg?fm=webp&fit=fill&w=1000',
  split2: 'https://images.ctfassets.net/drib7o8rcbyf/1Z0EStzVUSZJUjkCqHMkol/9c9c7601c4fa6b4532fd2c77803dbe36/REGENERATION_MODULE__SPA_375x563-min.jpg?fm=webp&fit=fill&w=1000',
  red: 'https://images.ctfassets.net/drib7o8rcbyf/1bWwZYCr12yWUXuz8WkTc8/48e6bc6818aa55c46721ea5b6cd110ac/Red_Lady_Portrait.jpg?fm=webp&fit=fill&w=1920',
};
---
<Layout title="Programme Ascent | No Limit Academy" description="Le programme Ascent — les fondations de l'elite. Coaching, science et performance pour les dirigeants ambitieux. A partir de 2 500 EUR par mois.">

<div class="page-hero">
  <div class="page-hero-bg" style={`background-image:url('${IMG.hero}')`}></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content">
    <p class="section-label">Programme</p>
    <h1 class="section-title" style="font-size:clamp(40px,6vw,72px)"><em>Ascent</em></h1>
    <p style="font-size:clamp(15px,1.6vw,20px);color:var(--gray-light);margin-top:16px;font-family:var(--font-mono)">A partir de 2 500 EUR / mois</p>
    <p style="font-size:18px;color:var(--gray-light);margin-top:16px;max-width:600px">Les fondations. Un coaching d'elite regulier et un suivi sante pour construire votre socle de performance durable.</p>
  </div>
</div>

<section class="section section-dark">
  <div class="section-center reveal">
    <p class="section-label">Ce qui est inclus</p>
    <h2 class="section-title">Les fondations de <em>l'excellence</em></h2>
  </div>
  <div class="science-grid reveal">
    <div class="science-card">
      <p class="science-icon">Coaching</p>
      <h3>3 seances / semaine</h3>
      <p>Seances avec un coach elite certifie, selectionne par notre comite d'anciens athletes. Chaque seance est documentee et analysee.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">Pack connecte</p>
      <h3>Bracelet + Bague NLA</h3>
      <p>Pack connecte inclus. Bracelet et bague integres au CRM No Limit Academy. Suivi biometrique continu.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">Sante</p>
      <h3>Bilan Lucis semestriel</h3>
      <p>Analyse de 180+ biomarqueurs deux fois par an. Vision complete de votre etat de sante preventive.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">Nutrition</p>
      <h3>Plan personnalise</h3>
      <p>Protocole nutritionnel adapte a vos biomarqueurs, votre agenda et vos objectifs de performance specifiques.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">Performance</p>
      <h3>Tableau de bord KPIs</h3>
      <p>Dashboard personnalise avec suivi de vos indicateurs cles de performance. Visible par vous et votre coach.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">Mental</p>
      <h3>1 seance mentale / mois</h3>
      <p>Seance mensuelle de performance mentale avec un specialiste du conditionnement psychologique de haut niveau.</p>
    </div>
  </div>
</section>

<section class="split reveal">
  <div class="split-img">
    <div class="split-img-bg" style={`background-image:url('${IMG.split}')`}></div>
  </div>
  <div class="split-body">
    <p class="section-label">La progression</p>
    <h2 class="section-title">Un socle. <em>Des fondations solides.</em></h2>
    <p class="section-desc">Ascent est concu pour les dirigeants qui veulent reprendre le controle de leur sante et de leur performance physique sans compromettre leur agenda charge.</p>
    <p class="section-desc">3 seances par semaine suffisent pour initier une transformation profonde quand chaque seance est concue avec precision par un coach de classe mondiale.</p>
    <a href="/candidature" class="btn btn-primary btn-arrow">Postuler pour Ascent</a>
  </div>
</section>

<section class="split split-reverse reveal">
  <div class="split-img">
    <div class="split-img-bg" style={`background-image:url('${IMG.split2}')`}></div>
  </div>
  <div class="split-body">
    <p class="section-label">Evolution</p>
    <h2 class="section-title">Evoluer vers <em>Summit</em></h2>
    <p class="section-desc">Les membres Ascent qui souhaitent aller plus loin peuvent evoluer vers Summit a tout moment. Aucune penalite, aucune perte de donnees. Votre historique suit votre progression.</p>
    <a href="/summit" class="btn btn-ghost btn-arrow">Decouvrir Summit</a>
  </div>
</section>

<section class="section section-darker">
  <div class="testimonial reveal">
    <p class="testimonial-quote">"Ascent m'a reappris ce que signifie etre en forme. Pas gym, pas regime. Une transformation profonde en 3 mois."</p>
    <p class="testimonial-author">Membre Ascent</p>
    <p class="testimonial-role">Directeur General, groupe industriel</p>
  </div>
</section>

<section class="cta-banner">
  <div class="cta-banner-bg" style={`background-image:url('${IMG.red}')`}></div>
  <div class="cta-banner-content">
    <p class="section-label reveal">Commencer</p>
    <h2 class="section-title reveal">Rejoindre Ascent.<br><em>Commencer maintenant.</em></h2>
    <p class="section-desc reveal">A partir de 2 500 EUR par mois. Sur candidature uniquement. 50 places par trimestre.</p>
    <div class="reveal" style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
      <a href="/candidature" class="btn btn-primary btn-arrow">Postuler pour Ascent</a>
      <a href="/programmes" class="btn btn-outline">Comparer les programmes</a>
    </div>
  </div>
</section>

</Layout>
