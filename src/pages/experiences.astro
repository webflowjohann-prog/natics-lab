---
import Layout from '../layouts/Layout.astro';
const IMG = {
  hero: 'https://images.ctfassets.net/drib7o8rcbyf/3nHzLEyA0EUbwptegIjvpR/d00dffbc475fe36f129523a6e672b1e6/REGENERATION_MODULE__ICONIC_SPACES_375x563-min.jpg?fm=webp&fit=fill&w=1920',
  arctic: 'https://images.ctfassets.net/drib7o8rcbyf/3nHzLEyA0EUbwptegIjvpR/d00dffbc475fe36f129523a6e672b1e6/REGENERATION_MODULE__ICONIC_SPACES_375x563-min.jpg?fm=webp&fit=fill&w=1200',
  biohacking: 'https://images.ctfassets.net/drib7o8rcbyf/7xaVBLqmztmYQGrXBg0pqx/01d2a0130ad7a05585663d9600b437eb/CORE_ANCILLARIES_MODULE__GF_375x563-min.jpg?fm=webp&fit=fill&w=1200',
  sommet: 'https://images.ctfassets.net/drib7o8rcbyf/1bWwZYCr12yWUXuz8WkTc8/48e6bc6818aa55c46721ea5b6cd110ac/Red_Lady_Portrait.jpg?fm=webp&fit=fill&w=1200',
  alpine: 'https://images.ctfassets.net/drib7o8rcbyf/3SSkmL8U5YBGKCPkJoIdib/07d03a08278a1f3576dc52cdb2ed5e79/CORE_ANCILLARIES_MODULE__STUDIO_PILATES_375x563-min.jpg?fm=webp&fit=fill&w=1200',
  masterclass: 'https://images.ctfassets.net/drib7o8rcbyf/64oMt8msJ0h1l75i0ejdfs/51022d60a8ac8c3915436d1ede080321/CORE_ANCILLARIES_MODULE__PT_375x563-min.jpg?fm=webp&fit=fill&w=1200',
  zoi: 'https://images.ctfassets.net/drib7o8rcbyf/1Z0EStzVUSZJUjkCqHMkol/9c9c7601c4fa6b4532fd2c77803dbe36/REGENERATION_MODULE__SPA_375x563-min.jpg?fm=webp&fit=fill&w=1200',
  concierge: 'https://images.ctfassets.net/drib7o8rcbyf/3jxErqCGFfGDk4HdpTvBhH/40e1d98bddae5be182a0eb5c65e56d59/REGENERATION_MODULE__Amenities_375x563-min.jpg?fm=webp&fit=fill&w=1200',
  red: 'https://images.ctfassets.net/drib7o8rcbyf/1bWwZYCr12yWUXuz8WkTc8/48e6bc6818aa55c46721ea5b6cd110ac/Red_Lady_Portrait.jpg?fm=webp&fit=fill&w=1920',
};
---
<Layout
  title="Expériences à la carte | No Limit Academy"
  description="Expéditions, retraites biohacking, masterclasses athlètes, upgrade Zoï. Disponibles séparément pour tous les membres NLA. Accès prioritaire VISION."
>

<div class="page-hero">
  <div class="page-hero-bg" style={`background-image:url('${IMG.hero}')`}></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content">
    <p class="section-label">Catalogue à la carte</p>
    <h1 class="section-title" style="font-size:clamp(40px,6vw,72px)">Les expériences<br><em>No Limit Academy</em></h1>
    <p style="font-size:18px;color:var(--gray-light);margin-top:16px;max-width:640px">Ces expériences sont optionnelles et disponibles séparément pour tous les membres NLA, quel que soit leur programme. Les membres VISION bénéficient d'un accès prioritaire et d'un tarif préférentiel sur chacune d'elles.</p>
  </div>
</div>

<section class="section section-dark">
  <div class="section-center reveal">
    <p class="section-label">Expéditions</p>
    <h2 class="section-title">L'extrême <em>révèle les leaders</em></h2>
    <p class="section-desc">Des expéditions conçues pour sortir les dirigeants de leur zone de confort. La pression de l'environnement hostile comme révélateur de leadership.</p>
  </div>
  <div class="experiences reveal">
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.arctic}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">7 jours · Laponie suédoise</span>
        <h3 class="experience-title">Expédition Arctique</h3>
        <p class="experience-desc">Tracking sur glace, aurores boréales, ateliers leadership en conditions extrêmes. Limité à 12 participants. Un programme conçu avec Explora Project.</p>
        <p style="font-size:13px;font-family:var(--font-mono);color:var(--gold);margin-top:12px">6 000 – 9 000 €</p>
      </div>
    </div>
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.alpine}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">5 jours · Alpes</span>
        <h3 class="experience-title">Traversée Alpine</h3>
        <p class="experience-desc">Altitude, froid, effort physique extrême. Leadership en milieu hostile. Accompagnement par des guides de haute montagne professionnels.</p>
        <p style="font-size:13px;font-family:var(--font-mono);color:var(--gold);margin-top:12px">4 000 – 6 000 €</p>
      </div>
    </div>
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.sommet}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">Annuel · Sur invitation</span>
        <h3 class="experience-title">Le Sommet No Limit</h3>
        <p class="experience-desc">Rassemblement annuel des membres, coachs et athlètes de classe mondiale. Lieu révélé 48 heures avant le départ. L'événement le plus attendu de l'année.</p>
        <p style="font-size:13px;font-family:var(--font-mono);color:var(--gold);margin-top:12px">Sur invitation</p>
      </div>
    </div>
  </div>
</section>

<section class="section section-darker">
  <div class="section-center reveal">
    <p class="section-label">Retraites &amp; diagnostics</p>
    <h2 class="section-title">Régénération et <em>optimisation</em></h2>
    <p class="section-desc">Des formats immersifs pour aller plus loin dans l'optimisation de votre biologie et de votre mental.</p>
  </div>
  <div class="experiences reveal">
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.biohacking}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">5 jours · Domaine privé</span>
        <h3 class="experience-title">Retraite Biohacking</h3>
        <p class="experience-desc">Diagnostics avancés, cryothérapie, breathwork, hyperbarie et optimisation de performance dans un domaine privé. Le protocole d'optimisation le plus complet.</p>
        <p style="font-size:13px;font-family:var(--font-mono);color:var(--gold);margin-top:12px">3 500 – 5 000 €</p>
      </div>
    </div>
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.zoi}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">1 journée · Clinique Zoï</span>
        <h3 class="experience-title">Upgrade Bilan Zoï</h3>
        <p class="experience-desc">Bilan de santé ultime avec la clinique Zoï : IRM corps entier, analyses génomiques avancées, protocole de longévité complet. Une vision de votre santé sur 20 ans.</p>
        <p style="font-size:13px;font-family:var(--font-mono);color:var(--gold);margin-top:12px">3 600 €</p>
      </div>
    </div>
  </div>
</section>

<section class="section section-dark">
  <div class="section-center reveal">
    <p class="section-label">Masterclasses &amp; services</p>
    <h2 class="section-title">Accès aux <em>meilleurs</em></h2>
  </div>
  <div class="experiences reveal">
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.masterclass}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">Demi-journée · Tous membres</span>
        <h3 class="experience-title">Masterclass Athlète</h3>
        <p class="experience-desc">Sessions exclusives avec d'anciens olympiens et champions du monde. Leadership, performance sous pression, résilience mentale. Des perspectives que seul l'élite connaît.</p>
        <p style="font-size:13px;font-family:var(--font-mono);color:var(--gold);margin-top:12px">500 – 1 000 €</p>
      </div>
    </div>
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.concierge}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">Mensuel · Option abonnement</span>
        <h3 class="experience-title">Conciergerie Bien-être 24/7</h3>
        <p class="experience-desc">Un concierge dédié pour gérer tous vos besoins bien-être : rendez-vous médicaux, réservations spa, kinésithérapeute, ostéopathe. Disponible à toute heure.</p>
        <p style="font-size:13px;font-family:var(--font-mono);color:var(--gold);margin-top:12px">800 €/mois</p>
      </div>
    </div>
  </div>
</section>

<section class="section section-darker">
  <div class="section-center reveal">
    <p class="section-label">Membres VISION</p>
    <h2 class="section-title">Accès prioritaire <em>et tarif préférentiel</em></h2>
    <p class="section-desc">Les membres VISION ont un accès en avant-première sur toutes les expériences NLA et bénéficient d'un tarif préférentiel sur chacune d'entre elles. Une valeur ajoutée exclusive pour le programme le plus exigeant.</p>
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-top:32px">
      <a href="/vision" class="btn btn-primary btn-arrow">Découvrir VISION</a>
      <a href="/programmes" class="btn btn-outline">Voir les programmes</a>
    </div>
  </div>
</section>

<section class="cta-banner">
  <div class="cta-banner-bg" style={`background-image:url('${IMG.red}')`}></div>
  <div class="cta-banner-content">
    <p class="section-label reveal">Rejoindre</p>
    <h2 class="section-title reveal">Votre prochaine expérience <em>commence ici</em></h2>
    <p class="section-desc reveal">Les expériences No Limit Academy sont réservées aux membres. Postulez maintenant pour accéder au calendrier complet.</p>
    <div class="reveal" style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
      <a href="/candidature" class="btn btn-primary btn-arrow">Postuler comme membre</a>
      <a href="/programmes" class="btn btn-outline">Voir les programmes</a>
    </div>
  </div>
</section>

</Layout>
