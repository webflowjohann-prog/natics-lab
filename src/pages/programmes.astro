---
import Layout from '../layouts/Layout.astro';
const IMG = {
  hero: 'https://images.ctfassets.net/drib7o8rcbyf/3nHzLEyA0EUbwptegIjvpR/d00dffbc475fe36f129523a6e672b1e6/REGENERATION_MODULE__ICONIC_SPACES_375x563-min.jpg?fm=webp&fit=fill&w=1920',
  pt: 'https://images.ctfassets.net/drib7o8rcbyf/64oMt8msJ0h1l75i0ejdfs/51022d60a8ac8c3915436d1ede080321/CORE_ANCILLARIES_MODULE__PT_375x563-min.jpg?fm=webp&fit=fill&w=800',
  spa: 'https://images.ctfassets.net/drib7o8rcbyf/1Z0EStzVUSZJUjkCqHMkol/9c9c7601c4fa6b4532fd2c77803dbe36/REGENERATION_MODULE__SPA_375x563-min.jpg?fm=webp&fit=fill&w=800',
  red: 'https://images.ctfassets.net/drib7o8rcbyf/1bWwZYCr12yWUXuz8WkTc8/48e6bc6818aa55c46721ea5b6cd110ac/Red_Lady_Portrait.jpg?fm=webp&fit=fill&w=1920',
};
---
<Layout
  title="Programmes | No Limit Academy"
  description="Trois niveaux d'adhésion : IMPACT, FLOW et VISION. Des fondations solides à la maîtrise totale. Choisissez votre engagement."
>

<div class="page-hero">
  <div class="page-hero-bg" style={`background-image:url('${IMG.hero}')`}></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content">
    <p class="section-label">Niveaux d'adhésion</p>
    <h1 class="section-title" style="font-size:clamp(40px,6vw,72px)">Trois voies vers la <em>performance absolue</em></h1>
    <p style="font-size:18px;color:var(--gray-light);margin-top:16px;max-width:640px">Chaque programme est un abonnement mensuel. Les expériences NLA — expéditions, retraites, masterclasses — sont disponibles séparément, à la carte, pour tous les membres.</p>
  </div>
</div>

<section class="section section-dark">
  <div class="tiers reveal">
    <div class="tier">
      <h3 class="tier-name">IMPACT</h3>
      <p class="tier-price">990 – 1 500 €/mois</p>
      <p class="tier-desc">Les fondations. Un coaching d'élite régulier et un suivi santé pour construire votre socle de performance durable.</p>
      <ul class="tier-features">
        <li>3 séances de coaching / semaine</li>
        <li>Pack connecté inclus (bracelet + bague → CRM NLA)</li>
        <li>Bilan Lucis semestriel (180+ biomarqueurs)</li>
        <li>Plan nutrition et sommeil personnalisé</li>
        <li>Dashboard KPIs performance</li>
        <li>1 séance mentale / mois</li>
      </ul>
      <a href="/impact" class="btn btn-outline btn-arrow">Découvrir IMPACT</a>
    </div>
    <div class="tier tier-featured">
      <h3 class="tier-name">FLOW</h3>
      <p class="tier-price">2 000 – 2 800 €/mois</p>
      <p class="tier-desc">La transformation complète. Tout IMPACT, plus sophrologie, breathwork, nutrition de précision et bilan trimestriel.</p>
      <ul class="tier-features">
        <li>Tout le programme IMPACT inclus</li>
        <li>Sophrologie et breathwork réguliers</li>
        <li>Nutrition de précision (micronutriments, chrononutrition)</li>
        <li>Bilan Lucis trimestriel</li>
        <li>Suivi mental bimensuel</li>
        <li>Accès réseau spécialistes NLA</li>
      </ul>
      <a href="/flow" class="btn btn-primary btn-arrow">Découvrir FLOW</a>
    </div>
    <div class="tier">
      <h3 class="tier-name">VISION</h3>
      <p class="tier-price">3 500 – 5 000 €/mois</p>
      <p class="tier-desc">L'ultime. Tout FLOW, plus neurofeedback, génomique, équipe médicale dédiée et communauté privée.</p>
      <ul class="tier-features">
        <li>Tout le programme FLOW inclus</li>
        <li>Séances de neurofeedback</li>
        <li>Analyse génomique et épigénétique</li>
        <li>Équipe médicale personnelle dédiée</li>
        <li>Communauté privée VISION</li>
        <li>Accès prioritaire aux expériences NLA</li>
      </ul>
      <a href="/vision" class="btn btn-outline btn-arrow">Découvrir VISION</a>
    </div>
  </div>
  <div class="section-center reveal" style="margin-top:48px">
    <p style="font-size:15px;color:var(--gray-mid);font-family:var(--font-mono)">Les expériences NLA (expéditions, retraites, masterclasses) sont optionnelles et disponibles <a href="/experiences" style="color:var(--gold);text-decoration:none">à la carte →</a></p>
  </div>
</section>

<section class="section section-darker">
  <div class="stats reveal">
    <div class="stat"><div class="stat-number">IMPACT</div><div class="stat-label">990 – 1 500 € / mois</div></div>
    <div class="stat"><div class="stat-number">FLOW</div><div class="stat-label">2 000 – 2 800 € / mois</div></div>
    <div class="stat"><div class="stat-number">VISION</div><div class="stat-label">3 500 – 5 000 € / mois</div></div>
    <div class="stat"><div class="stat-number">100%</div><div class="stat-label">Déductible entreprise</div></div>
  </div>
</section>

<section class="split reveal">
  <div class="split-img">
    <div class="split-img-bg" style={`background-image:url('${IMG.pt}')`}></div>
  </div>
  <div class="split-body">
    <p class="section-label">Financement</p>
    <h2 class="section-title">Votre entreprise <em>finance votre performance</em></h2>
    <p class="section-desc">No Limit Academy s'intègre dans les dispositifs légaux de santé au travail, QVCT et formation professionnelle. L'adhésion peut être intégralement prise en charge par votre entreprise.</p>
    <a href="/financement" class="btn btn-ghost btn-arrow">En savoir plus</a>
  </div>
</section>

<section class="split split-reverse reveal">
  <div class="split-img">
    <div class="split-img-bg" style={`background-image:url('${IMG.spa}')`}></div>
  </div>
  <div class="split-body">
    <p class="section-label">Pack connecté</p>
    <h2 class="section-title">Bracelet + Bague.<br><em>CRM No Limit.</em></h2>
    <p class="section-desc">Chaque adhésion inclut un pack bracelet et bague connectés, intégrés directement au CRM No Limit Academy. Vos données biométriques alimentent votre tableau de bord en temps réel, accessible par votre coach à chaque séance.</p>
    <a href="/science" class="btn btn-ghost btn-arrow">Découvrir la science</a>
  </div>
</section>

<section class="cta-banner">
  <div class="cta-banner-bg" style={`background-image:url('${IMG.red}')`}></div>
  <div class="cta-banner-content">
    <p class="section-label reveal">Accès limité</p>
    <h2 class="section-title reveal">50 places par trimestre. <em>Sur candidature.</em></h2>
    <p class="section-desc reveal">No Limit Academy n'est pas un service. C'est un engagement entre vous et les meilleurs coachs du monde.</p>
    <div class="reveal" style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
      <a href="/candidature" class="btn btn-primary btn-arrow">Postuler maintenant</a>
    </div>
  </div>
</section>

</Layout>
