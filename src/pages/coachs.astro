---
import Layout from '../layouts/Layout.astro';
const IMG = {
  hero: 'https://images.ctfassets.net/drib7o8rcbyf/64oMt8msJ0h1l75i0ejdfs/51022d60a8ac8c3915436d1ede080321/CORE_ANCILLARIES_MODULE__PT_375x563-min.jpg?fm=webp&fit=fill&w=1920',
  pt600: 'https://images.ctfassets.net/drib7o8rcbyf/64oMt8msJ0h1l75i0ejdfs/51022d60a8ac8c3915436d1ede080321/CORE_ANCILLARIES_MODULE__PT_375x563-min.jpg?fm=webp&fit=fill&w=600',
  pilates600: 'https://images.ctfassets.net/drib7o8rcbyf/3SSkmL8U5YBGKCPkJoIdib/07d03a08278a1f3576dc52cdb2ed5e79/CORE_ANCILLARIES_MODULE__STUDIO_PILATES_375x563-min.jpg?fm=webp&fit=fill&w=600',
  spa600: 'https://images.ctfassets.net/drib7o8rcbyf/1Z0EStzVUSZJUjkCqHMkol/9c9c7601c4fa6b4532fd2c77803dbe36/REGENERATION_MODULE__SPA_375x563-min.jpg?fm=webp&fit=fill&w=600',
  amenities600: 'https://images.ctfassets.net/drib7o8rcbyf/3jxErqCGFfGDk4HdpTvBhH/40e1d98bddae5be182a0eb5c65e56d59/REGENERATION_MODULE__Amenities_375x563-min.jpg?fm=webp&fit=fill&w=600',
  gf600: 'https://images.ctfassets.net/drib7o8rcbyf/7xaVBLqmztmYQGrXBg0pqx/01d2a0130ad7a05585663d9600b437eb/CORE_ANCILLARIES_MODULE__GF_375x563-min.jpg?fm=webp&fit=fill&w=600',
  iconic600: 'https://images.ctfassets.net/drib7o8rcbyf/3nHzLEyA0EUbwptegIjvpR/d00dffbc475fe36f129523a6e672b1e6/REGENERATION_MODULE__ICONIC_SPACES_375x563-min.jpg?fm=webp&fit=fill&w=600',
  red600: 'https://images.ctfassets.net/drib7o8rcbyf/1bWwZYCr12yWUXuz8WkTc8/48e6bc6818aa55c46721ea5b6cd110ac/Red_Lady_Portrait.jpg?fm=webp&fit=fill&w=600',
  red: 'https://images.ctfassets.net/drib7o8rcbyf/1bWwZYCr12yWUXuz8WkTc8/48e6bc6818aa55c46721ea5b6cd110ac/Red_Lady_Portrait.jpg?fm=webp&fit=fill&w=1920',
};
---
<Layout title="Nos Coachs | No Limit Academy" description="Selectionnes, jamais recrutes. Decouvrez les coachs d'elite No Limit Academy, passes par un processus de selection en 5 etapes.">

<div class="page-hero">
  <div class="page-hero-bg" style={`background-image:url('${IMG.hero}')`}></div>
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content">
    <p class="section-label">Notre reseau</p>
    <h1 class="section-title" style="font-size:clamp(40px,6vw,72px)">Selectionnes.<br><em>Jamais recrutes.</em></h1>
    <p style="font-size:18px;color:var(--gray-light);margin-top:16px;max-width:600px">Chaque coach passe un processus de selection rigoureux en 5 etapes. Le parcours d'excellence rencontre la maitrise du coaching.</p>
  </div>
</div>

<section class="section section-dark">
  <div class="section-center reveal">
    <p class="section-label">Les fondateurs</p>
    <h2 class="section-title">Crees par des <em>champions</em></h2>
    <p class="section-desc">No Limit Academy est fonde par deux hommes qui ont chacun atteint le sommet de leur discipline. Leur comite de selection fixe les standards d'excellence de l'ensemble du reseau.</p>
  </div>
  <div class="coaches reveal">
    <div class="coach">
      <div class="coach-img" style={`background-image:url('${IMG.pt600}')`}></div>
      <div class="coach-info">
        <h3 class="coach-name">Johann Langenberg</h3>
        <p class="coach-role">Co-fondateur / Comite de selection</p>
        <p class="coach-bio">Ancien n1 mondial et 5x champion d'Europe. 25 ans d'expertise en creation digitale, innovation IA et production video cinematique. Dirige le comite de selection des coachs.</p>
      </div>
    </div>
    <div class="coach">
      <div class="coach-img" style={`background-image:url('${IMG.pilates600}')`}></div>
      <div class="coach-info">
        <h3 class="coach-name">Dustin Arnold</h3>
        <p class="coach-role">Co-fondateur / Coach principal</p>
        <p class="coach-bio">Ancien champion de boxe de haut niveau. Fondateur de NATICS, studio prive a Bois-Guillaume. Methode IMPACT / FLOW / VISION. Pionnier du coaching de dirigeants en France.</p>
      </div>
    </div>
    <div class="coach">
      <div class="coach-img" style={`background-image:url('${IMG.spa600}')`}></div>
      <div class="coach-info">
        <h3 class="coach-name">Coach elite</h3>
        <p class="coach-role">Force et conditionnement</p>
        <p class="coach-bio">Coach certifie performance d'elite. Ancien preparateur physique en Ligue 1. Specialiste des protocoles d'entrainement adaptes aux dirigeants sous haute pression.</p>
      </div>
    </div>
    <div class="coach">
      <div class="coach-img" style={`background-image:url('${IMG.amenities600}')`}></div>
      <div class="coach-info">
        <h3 class="coach-name">Expert sante</h3>
        <p class="coach-role">Nutrition et recuperation</p>
        <p class="coach-bio">Expert en nutrition sportive de haut niveau. Specialise dans les modes de vie executive sous haute pression et l'optimisation des deplacements internationaux.</p>
      </div>
    </div>
  </div>
</section>

<section class="section section-darker">
  <div class="coaches reveal">
    <div class="coach">
      <div class="coach-img" style={`background-image:url('${IMG.gf600}')`}></div>
      <div class="coach-info">
        <h3 class="coach-name">Expert mental</h3>
        <p class="coach-role">Performance mentale</p>
        <p class="coach-bio">Psychologue du sport de haut niveau. 10 ans d'experience avec des athletes olympiques. Adapte les methodes de conditionnement mental a la realite du dirigeant.</p>
      </div>
    </div>
    <div class="coach">
      <div class="coach-img" style={`background-image:url('${IMG.iconic600}')`}></div>
      <div class="coach-info">
        <h3 class="coach-name">Specialiste sante</h3>
        <p class="coach-role">Sante preventive</p>
        <p class="coach-bio">Medecin specialise en medecine preventive et longevite. Partenaire Lucis.health. Interprete vos biomarqueurs et construit votre protocole de sante personnalise.</p>
      </div>
    </div>
    <div class="coach">
      <div class="coach-img" style={`background-image:url('${IMG.red600}')`}></div>
      <div class="coach-info">
        <h3 class="coach-name">Expert mobilite</h3>
        <p class="coach-role">Mouvement et mobilite</p>
        <p class="coach-bio">Specialiste du mouvement fonctionnel. Ancienne danseuse professionnelle reconvertie. Cree des programmes de mobilite adaptes aux contraintes du dirigeant.</p>
      </div>
    </div>
    <div class="coach">
      <div class="coach-img" style={`background-image:url('${IMG.pilates600}')`}></div>
      <div class="coach-info">
        <h3 class="coach-name">Expert voyageur</h3>
        <p class="coach-role">Performance en deplacement</p>
        <p class="coach-bio">Specialiste du maintien de la performance pour les executives qui voyagent 200+ jours par an. Jet lag, adaptatation, routines nomades.</p>
      </div>
    </div>
  </div>
</section>

<section class="section section-dark">
  <div class="section-center reveal">
    <p class="section-label">Le processus</p>
    <h2 class="section-title">5 etapes de <em>selection</em></h2>
    <p class="section-desc">Aucun coach ne rejoint No Limit Academy sans passer par notre processus de selection complet. L'excellence n'est pas negociable.</p>
  </div>
  <div class="science-grid reveal">
    <div class="science-card">
      <p class="science-icon">Etape 01</p>
      <h3>Dossier de candidature</h3>
      <p>Parcours complet, certifications, experiences avec des profils executives et references verifiables. Seuls 10% passent cette etape.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">Etape 02</p>
      <h3>Entretien de competences</h3>
      <p>Session approfondie avec les fondateurs. Methodologie, vision du coaching, ethique, intelligence relationnelle.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">Etape 03</p>
      <h3>Session de coaching observee</h3>
      <p>Le candidat dirige une seance complete avec un membre du reseau. Evaluation de la qualite, de la precision et de la relation.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">Etape 04</p>
      <h3>Validation du comite</h3>
      <p>Vote du comite compose d'anciens athletes de classe mondiale. La majorite qualifiee est requise pour toute admission.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">Etape 05</p>
      <h3>Formation NLA</h3>
      <p>Onboarding et formation aux methodes, outils et standards No Limit Academy. Integration dans l'ecosysteme CRM et protocoles.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">Continu</p>
      <h3>Evaluation permanente</h3>
      <p>Chaque coach est evalue en continu par les membres et le comite. L'excellence ne s'arrete pas a l'admission.</p>
    </div>
  </div>
</section>

<section class="cta-banner">
  <div class="cta-banner-bg" style={`background-image:url('${IMG.red}')`}></div>
  <div class="cta-banner-content">
    <p class="section-label reveal">Rejoindre le reseau</p>
    <h2 class="section-title reveal">Vous etes coach d'elite ?<br><em>Nous vous cherchons.</em></h2>
    <p class="section-desc reveal">Postulez pour rejoindre le reseau No Limit Academy. Si votre parcours est exceptionnel, notre comite vous contactera.</p>
    <div class="reveal" style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
      <a href="/candidature" class="btn btn-primary btn-arrow">Postuler comme coach</a>
      <a href="/candidature" class="btn btn-outline btn-arrow">Devenir membre</a>
    </div>
  </div>
</section>

</Layout>
