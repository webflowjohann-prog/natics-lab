---
import Layout from '../layouts/Layout.astro';
const IMG = {
  hero: 'https://images.ctfassets.net/drib7o8rcbyf/1bWwZYCr12yWUXuz8WkTc8/48e6bc6818aa55c46721ea5b6cd110ac/Red_Lady_Portrait.jpg?fm=webp&fit=fill&w=1920',
  pt: 'https://images.ctfassets.net/drib7o8rcbyf/64oMt8msJ0h1l75i0ejdfs/51022d60a8ac8c3915436d1ede080321/CORE_ANCILLARIES_MODULE__PT_375x563-min.jpg?fm=webp&fit=fill&w=800',
  spa: 'https://images.ctfassets.net/drib7o8rcbyf/1Z0EStzVUSZJUjkCqHMkol/9c9c7601c4fa6b4532fd2c77803dbe36/REGENERATION_MODULE__SPA_375x563-min.jpg?fm=webp&fit=fill&w=800',
  iconic: 'https://images.ctfassets.net/drib7o8rcbyf/3nHzLEyA0EUbwptegIjvpR/d00dffbc475fe36f129523a6e672b1e6/REGENERATION_MODULE__ICONIC_SPACES_375x563-min.jpg?fm=webp&fit=fill&w=800',
  gf: 'https://images.ctfassets.net/drib7o8rcbyf/7xaVBLqmztmYQGrXBg0pqx/01d2a0130ad7a05585663d9600b437eb/CORE_ANCILLARIES_MODULE__GF_375x563-min.jpg?fm=webp&fit=fill&w=1000',
  pilates: 'https://images.ctfassets.net/drib7o8rcbyf/3SSkmL8U5YBGKCPkJoIdib/07d03a08278a1f3576dc52cdb2ed5e79/CORE_ANCILLARIES_MODULE__STUDIO_PILATES_375x563-min.jpg?fm=webp&fit=fill&w=600',
  amenities: 'https://images.ctfassets.net/drib7o8rcbyf/3jxErqCGFfGDk4HdpTvBhH/40e1d98bddae5be182a0eb5c65e56d59/REGENERATION_MODULE__Amenities_375x563-min.jpg?fm=webp&fit=fill&w=600',
};
---
<Layout
  title="No Limit Academy | Coaching d'Élite pour Dirigeants Visionnaires"
  description="No Limit Academy connecte les meilleurs coachs avec les dirigeants visionnaires. Santé préventive, expériences transformationnelles et communauté de leaders."
>

<section class="hero">
  <div class="hero-bg" style={`background-image:url('${IMG.hero}')`}></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <p class="hero-label">Sur candidature uniquement</p>
    <h1 class="hero-title">Là où les leaders deviennent <em>inarrêtables</em></h1>
    <p class="hero-sub">Coaching d'élite, science préventive et expériences transformationnelles. Conçu pour les dirigeants qui refusent les limites. Chaque adhésion inclut un pack bracelet et bague connectés au CRM No Limit Academy.</p>
    <div class="hero-ctas">
      <a href="/candidature" class="btn btn-primary btn-arrow">Devenir membre</a>
      <a href="/concept" class="btn btn-outline">Découvrir la vision</a>
    </div>
  </div>
  <div class="hero-scroll">
    <span>Défiler</span>
    <div class="hero-scroll-line"></div>
  </div>
</section>

<section class="section section-dark">
  <div class="section-center reveal">
    <p class="section-label">Les 3 piliers</p>
    <h2 class="section-title">Un écosystème.<br><em>Un potentiel illimité.</em></h2>
    <p class="section-desc">No Limit Academy est la première plateforme au monde qui réunit coaching d'élite, science préventive et expériences extrêmes dans un seul écosystème pour dirigeants.</p>
  </div>
  <div class="pillars reveal">
    <div class="pillar">
      <div class="pillar-img" style={`background-image:url('${IMG.pt}')`}></div>
      <div class="pillar-content">
        <p class="pillar-number">01</p>
        <h3 class="pillar-title">Coaching d'élite</h3>
        <p class="pillar-text">Des coachs triés sur le volet par un comité d'anciens athlètes de haut niveau mondial. Aucun compromis sur l'excellence.</p>
        <a href="/coachs" class="pillar-link">Découvrir nos coachs</a>
      </div>
    </div>
    <div class="pillar">
      <div class="pillar-img" style={`background-image:url('${IMG.spa}')`}></div>
      <div class="pillar-content">
        <p class="pillar-number">02</p>
        <h3 class="pillar-title">Science préventive</h3>
        <p class="pillar-text">180+ biomarqueurs analysés. Suivi longitudinal. Recommandations personnalisées par des experts médicaux.</p>
        <a href="/science" class="pillar-link">Explorer la science</a>
      </div>
    </div>
    <div class="pillar">
      <div class="pillar-img" style={`background-image:url('${IMG.iconic}')`}></div>
      <div class="pillar-content">
        <p class="pillar-number">03</p>
        <h3 class="pillar-title">Expériences transformationnelles</h3>
        <p class="pillar-text">Expéditions extrêmes, retraites exclusives et événements sur invitation. À la carte, réservés aux membres.</p>
        <a href="/experiences" class="pillar-link">Voir le catalogue</a>
      </div>
    </div>
  </div>
</section>

<section class="split reveal">
  <div class="split-img">
    <div class="split-img-bg" style={`background-image:url('${IMG.gf}')`}></div>
  </div>
  <div class="split-body">
    <p class="section-label">La vision</p>
    <h2 class="section-title">Forgé par l'élite.<br>Pour ceux qui <em>dirigent.</em></h2>
    <p class="section-desc">Fondé par Johann Langenberg, ancien numéro 1 mondial et 5 fois champion d'Europe, et Dustin Arnold, ancien champion de boxe et fondateur de NATICS, studio privé à Bois-Guillaume.</p>
    <p class="section-desc">La méthode repose sur trois axes — IMPACT, FLOW, VISION — pour une progression durable alliant performance physique, équilibre et maîtrise du corps.</p>
    <a href="/coachs" class="btn btn-ghost btn-arrow">Découvrir les fondateurs</a>
  </div>
</section>

<section class="section section-darker">
  <div class="stats reveal">
    <div class="stat"><div class="stat-number">180+</div><div class="stat-label">Biomarqueurs suivis</div></div>
    <div class="stat"><div class="stat-number">50</div><div class="stat-label">Membres par trimestre</div></div>
    <div class="stat"><div class="stat-number">98%</div><div class="stat-label">Sélectivité des candidatures</div></div>
    <div class="stat"><div class="stat-number">24/7</div><div class="stat-label">Conciergerie bien-être</div></div>
  </div>
</section>

<section class="section section-dark">
  <div class="section-center reveal">
    <p class="section-label">Programmes socles</p>
    <h2 class="section-title">Trois niveaux.<br><em>Une progression claire.</em></h2>
    <p class="section-desc">Choisissez votre niveau de départ. Les expériences transformationnelles (expéditions, retraites, masterclasses) sont disponibles séparément, à la carte, pour tous les membres.</p>
  </div>
  <div class="tiers reveal">
    <div class="tier">
      <h3 class="tier-name">IMPACT</h3>
      <p class="tier-price">990 – 1 500 €/mois</p>
      <p class="tier-desc">Les fondations. Coaching régulier, pack connecté et suivi santé pour construire votre socle de performance.</p>
      <ul class="tier-features">
        <li>3 séances hebdomadaires avec coach élite certifié</li>
        <li>Pack connecté inclus (bracelet + bague CRM NLA)</li>
        <li>Bilan Lucis semestriel (180+ biomarqueurs)</li>
        <li>Plan personnalisé nutrition &amp; sommeil</li>
        <li>Dashboard performance avec suivi KPIs</li>
        <li>Séance mensuelle de performance mentale</li>
      </ul>
      <a href="/impact" class="btn btn-outline btn-arrow">Découvrir IMPACT</a>
    </div>
    <div class="tier tier-featured">
      <h3 class="tier-name">FLOW</h3>
      <p class="tier-price">2 000 – 2 800 €/mois</p>
      <p class="tier-desc">L'équilibre. Tout IMPACT plus sophrologie, breathwork, nutrition de précision, bilan trimestriel et spécialistes.</p>
      <ul class="tier-features">
        <li>Tout le programme IMPACT inclus</li>
        <li>Sophrologie &amp; breathwork réguliers</li>
        <li>Nutrition de précision (micronutriments, chrononutrition)</li>
        <li>Bilan Lucis trimestriel + diagnostics avancés</li>
        <li>Suivi mental bimensuel</li>
        <li>Accès réseau de spécialistes NLA</li>
      </ul>
      <a href="/flow" class="btn btn-primary btn-arrow">Découvrir FLOW</a>
    </div>
    <div class="tier">
      <h3 class="tier-name">VISION</h3>
      <p class="tier-price">3 500 – 5 000 €/mois</p>
      <p class="tier-desc">La maîtrise totale. Tout FLOW plus neurofeedback, génomique, équipe médicale dédiée et accès prioritaire aux expériences.</p>
      <ul class="tier-features">
        <li>Tout le programme FLOW inclus</li>
        <li>Neurofeedback (ondes cérébrales, focus, résilience)</li>
        <li>Analyse génomique et épigénétique</li>
        <li>Équipe médicale personnelle dédiée</li>
        <li>Communauté privée VISION</li>
        <li>Accès prioritaire + tarif préférentiel expériences NLA</li>
      </ul>
      <a href="/vision" class="btn btn-outline btn-arrow">Découvrir VISION</a>
    </div>
  </div>
  <p style="text-align:center;margin-top:32px;font-size:13px;color:var(--gray);font-family:var(--font-mono)">
    Les expériences (expéditions, retraites, masterclasses) sont optionnelles — <a href="/experiences" style="color:var(--gold)">catalogue à la carte →</a>
  </p>
</section>

<section class="section section-darker">
  <div class="reveal">
    <p class="section-label">Nos coachs</p>
    <h2 class="section-title">Sélectionnés. <em>Jamais recrutés.</em></h2>
    <p class="section-desc">Chaque coach de notre réseau passe un processus de sélection rigoureux en 5 étapes. Le parcours d'excellence rencontre la maîtrise du coaching et l'intelligence relationnelle.</p>
  </div>
  <div class="coaches reveal">
    <div class="coach">
      <div class="coach-img" style={`background-image:url('${IMG.pt}')`}></div>
      <div class="coach-info">
        <h3 class="coach-name">Johann L.</h3>
        <p class="coach-role">Co-fondateur / Comité de sélection</p>
        <p class="coach-bio">Ancien n°1 mondial et 5× champion d'Europe. 25 ans d'expertise en création digitale, innovation IA et production vidéo cinématique.</p>
      </div>
    </div>
    <div class="coach">
      <div class="coach-img" style={`background-image:url('${IMG.pilates}')`}></div>
      <div class="coach-info">
        <h3 class="coach-name">Dustin A.</h3>
        <p class="coach-role">Co-fondateur / Coach principal</p>
        <p class="coach-bio">Ancien champion de boxe. Fondateur de NATICS. Méthode IMPACT / FLOW / VISION.</p>
      </div>
    </div>
    <div class="coach">
      <div class="coach-img" style={`background-image:url('${IMG.spa}')`}></div>
      <div class="coach-info">
        <h3 class="coach-name">Coach élite</h3>
        <p class="coach-role">Force et conditionnement</p>
        <p class="coach-bio">Coach certifié performance d'élite. Spécialiste des protocoles d'entraînement adaptés aux dirigeants sous haute pression.</p>
      </div>
    </div>
    <div class="coach">
      <div class="coach-img" style={`background-image:url('${IMG.amenities}')`}></div>
      <div class="coach-info">
        <h3 class="coach-name">Expert santé</h3>
        <p class="coach-role">Nutrition et récupération</p>
        <p class="coach-bio">Expert en nutrition sportive. Spécialisé dans les modes de vie executive sous haute pression.</p>
      </div>
    </div>
  </div>
  <div style="text-align:center;margin-top:48px" class="reveal">
    <a href="/coachs" class="btn btn-ghost btn-arrow">Voir tous les coachs</a>
  </div>
</section>

<section class="section section-dark">
  <div class="reveal">
    <p class="section-label">Expériences — catalogue à la carte</p>
    <h2 class="section-title">Au-delà de la <em>zone de confort</em></h2>
    <p class="section-desc">Des expéditions et événements réservés aux membres NLA. Optionnels, facturés séparément de votre programme socle. Chacun est une expérience qui transforme un dirigeant.</p>
  </div>
  <div class="experiences reveal">
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.iconic.replace('w=800','w=1200')}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">6 000 – 9 000 € · 7 jours</span>
        <h3 class="experience-title">Expédition Leadership Arctique</h3>
        <p class="experience-desc">Laponie suédoise. Tracking sur glace, aurores boréales, ateliers leadership en conditions extrêmes. Limité à 12 participants.</p>
      </div>
    </div>
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.gf.replace('w=1000','w=800')}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">3 500 – 5 000 € · 5 jours</span>
        <h3 class="experience-title">Retraite Biohacking Executive</h3>
        <p class="experience-desc">Diagnostics avancés, cryothérapie, breathwork et optimisation de performance dans un domaine privé.</p>
      </div>
    </div>
    <div class="experience">
      <div class="experience-img" style={`background-image:url('${IMG.hero.replace('w=1920','w=1200')}')`}></div>
      <div class="experience-content">
        <span class="experience-tag">Sur invitation · Annuel</span>
        <h3 class="experience-title">Le Sommet No Limit</h3>
        <p class="experience-desc">Rassemblement annuel des membres et athlètes de classe mondiale. Lieu révélé 48 heures avant le départ.</p>
      </div>
    </div>
  </div>
  <div style="text-align:center;margin-top:40px" class="reveal">
    <a href="/experiences" class="btn btn-ghost btn-arrow">Voir tout le catalogue</a>
  </div>
</section>

<section class="section section-darker">
  <div class="testimonial reveal">
    <p class="testimonial-quote">« Depuis 20 ans, je dirige des entreprises dans la tourmente. No Limit Academy est le premier programme qui m'a donné le sentiment que quelqu'un me guidait à travers la mienne. »</p>
    <p class="testimonial-author">Témoignage futur membre</p>
    <p class="testimonial-role">PDG, entreprise du CAC 40</p>
  </div>
</section>

<section class="section section-dark">
  <div class="section-center reveal">
    <p class="section-label">La science</p>
    <h2 class="section-title">La performance guidée par les <em>données</em></h2>
    <p class="section-desc">En partenariat avec Lucis.health, nous offrons l'analyse de santé préventive la plus complète du marché, intégrée directement dans votre programme.</p>
  </div>
  <div class="science-grid reveal">
    <div class="science-card">
      <p class="science-icon">01 / Biomarqueurs</p>
      <h3>180+ marqueurs analysés</h3>
      <p>Profils cardiométaboliques, hormonaux, inflammatoires, hépatiques, rénaux et micronutriments. Bien au-delà d'un bilan classique.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">02 / Suivi</p>
      <h3>Monitoring longitudinal</h3>
      <p>Vos données évoluent avec vous. Suivez vos progrès sur des mois et des années avec un tableau de bord dynamique.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">03 / Wearables</p>
      <h3>Intégration temps réel</h3>
      <p>Oura Ring, Whoop, Apple Watch. Vos données wearables alimentent directement le tableau de bord de votre coach.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">04 / Nutrition</p>
      <h3>Alimentation de précision</h3>
      <p>Protocoles nutritionnels personnalisés adaptés à vos biomarqueurs et votre agenda de déplacements.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">05 / Récupération</p>
      <h3>Sommeil et régénération</h3>
      <p>Analyse avancée du sommeil. Protocoles conçus pour les dirigeants qui voyagent 200 jours par an.</p>
    </div>
    <div class="science-card">
      <p class="science-icon">06 / Mental</p>
      <h3>Performance mentale</h3>
      <p>Conditionnement mental de niveau olympique. Fatigue décisionnelle, focus, résilience au stress.</p>
    </div>
  </div>
</section>

<section class="section section-darker">
  <div class="section-center reveal">
    <p class="section-label">Partenaires</p>
    <h2 class="section-title">Le Cercle <em>No Limit</em></h2>
    <p class="section-desc">Un écosystème de marques premium intégré à votre expérience. Pas de la publicité. Des prescriptions d'excellence.</p>
  </div>
  <div class="partners-grid reveal">
    <span>Lucis.health</span>
    <span>Explora Project</span>
    <span>Oura</span>
    <span>Whoop</span>
    <span>Hyperice</span>
    <span>Thorne</span>
    <span>NATICS</span>
    <span>On Running</span>
    <span>Tag Heuer</span>
  </div>
</section>

<section class="split split-reverse reveal">
  <div class="split-img">
    <div class="split-img-bg" style={`background-image:url('${IMG.iconic.replace('w=800','w=1000')}')`}></div>
  </div>
  <div class="split-body">
    <p class="section-label">Pour les investisseurs</p>
    <h2 class="section-title">Une opportunité à <em>10 000 milliards</em></h2>
    <p class="section-desc">Le marché mondial du bien-être atteindra 10 000 milliards de dollars d'ici 2030. No Limit Academy se situe à l'intersection du wellness de luxe, de la tech sportive et de la santé préventive.</p>
    <p class="section-desc">L'adhésion Equinox à 40 000 dollars par an a plus de 1 000 personnes en liste d'attente. Nous construisons quelque chose de plus intime, de plus intelligent et de plus accessible.</p>
    <a href="/investisseurs" class="btn btn-ghost btn-arrow">Demander le deck</a>
  </div>
</section>

<section class="cta-banner">
  <div class="cta-banner-bg" style={`background-image:url('${IMG.hero}')`}></div>
  <div class="cta-banner-content">
    <p class="section-label reveal">Accès limité</p>
    <h2 class="section-title reveal">50 nouveaux membres <em>par trimestre</em></h2>
    <p class="section-desc reveal">No Limit Academy n'est pas une application. C'est un engagement entre vous et les meilleurs coachs du monde. Postulez maintenant pour entamer la conversation.</p>
    <div class="reveal" style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
      <a href="/candidature" class="btn btn-primary btn-arrow">Postuler comme membre</a>
      <a href="/candidature" class="btn btn-outline btn-arrow">Postuler comme coach</a>
    </div>
  </div>
</section>

</Layout>
